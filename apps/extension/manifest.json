{
  "manifest_version": 3,
  "name": "xhelix Browser Bridge",
  "version": "0.1.0",
  "description": "Reports browser tab and navigation events to the xhelix daemon for per-tab connection attribution.",
  "permissions": [
    "tabs",
    "webNavigation",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
